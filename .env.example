# Smart Bot - Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.

# GeekNow API (primary)
GEEKNOW_API_KEY=sk-your-geeknow-key-here
GEEKNOW_BASE_URL=https://api.geeknow.ai/v1
GEEKNOW_MODEL=gpt-4o-mini

# Custom API (optional OpenAI-compatible backup)
CUSTOM_API_KEY=sk-your-custom-api-key-here
CUSTOM_API_BASE=https://api.example.com/v1
CUSTOM_API_MODEL=gpt-4o-mini

# OpenAI
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Zhipu GLM
ZHIPU_API_KEY=your-zhipu-api-key-here
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=glm-4-flash

# DeepSeek
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
