NODE_ENV=development
API_PORT=3200
WEB_URL=http://127.0.0.1:3100
USE_LOCAL_STORE=true
DATABASE_PROVIDER=postgresql
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/smart_kefu
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
LOCAL_STORAGE_ROOT=./storage
DESIGN_PLATFORM_ADAPTER=art_image_local
DESIGN_PLATFORM_BASE_URL=http://127.0.0.1:3000
DESIGN_PLATFORM_API_KEY=replace-with-design-platform-key
DESIGN_PLATFORM_ACCESS_TOKEN=replace-with-design-platform-login-access-token
DESIGN_PLATFORM_COOKIE=art_access_token=replace; art_refresh_token=replace
DESIGN_PLATFORM_DEVICE_ID=replace-with-activated-device-id
DESIGN_PLATFORM_CALLBACK_API_KEY=replace-with-callback-key
HIGH_VALUE_AMOUNT_CNY=10000
DESIGN_TIMEOUT_MINUTES=20
DESIGN_DEFAULT_OUTPUT_COUNT=6
